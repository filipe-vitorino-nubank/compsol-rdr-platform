# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key

# Google Sheets
VITE_SHEET_ID=your-google-sheet-id

# Slack
VITE_SLACK_PROXY_URL=https://your-apps-script-url/exec
VITE_SLACK_PROXY_TOKEN=your-proxy-token
VITE_SLACK_TEAM_ID=your-slack-team-id
VITE_SLACK_DOMAIN=nubank.slack.com

# GCP / Vertex AI
VITE_GCP_PROJECT_ID=your-gcp-project-id
VITE_GCP_LOCATION=us-central1
VITE_GEMINI_MODEL=gemini-2.0-flash-001

# Glean
VITE_GLEAN_URL=https://your-glean-instance.glean.com/chat
